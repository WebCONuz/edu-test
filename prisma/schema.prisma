generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUM TURLAR
// ============================================

enum UserRole {
  super_admin
  admin
  teacher
}

enum QuestionType {
  single
  multiple
}

// ============================================
// 1. TIZIM FOYDALANUVCHILARI
// ============================================

model User {
  id        String   @id @default(uuid())
  fullName  String   @map("full_name") @db.VarChar(100)
  email     String   @unique @db.VarChar(150)
  password  String   @db.VarChar(255)
  role      UserRole @default(admin)
  isActive  Boolean  @default(true) @map("is_active")

  createdById String? @map("created_by")
  createdBy   User?   @relation("AdminCreatedBy", fields: [createdById], references: [id])
  createdUsers User[] @relation("AdminCreatedBy")
  refreshToken String? @map("refresh_token")
  resetPasswordToken   String?   @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  subjects  Subject[]
  questions Question[]

  @@map("users")
}

// ============================================
// 2. FANLAR / KATEGORIYALAR
// ============================================

model Subject {
  id          String  @id @default(uuid())
  name        String  @unique @db.VarChar(100)
  description String?
  isActive    Boolean @default(true) @map("is_active")

  createdById String? @map("created_by")
  createdBy   User?   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  questions    Question[]
  testSessions TestSession[]

  @@map("subjects")
}

// ============================================
// 3. SAVOLLAR
// ============================================

model Question {
  id           String       @id @default(uuid())
  questionText String       @map("question_text")
  questionType QuestionType @default(single) @map("question_type")
  imageUrl     String?      @map("image_url") @db.VarChar(500)
  isActive     Boolean      @default(true) @map("is_active")
  source       String       @default("manual") @db.VarChar(50) // 'manual' | 'file_import'

  subjectId String  @map("subject_id")
  subject   Subject @relation(fields: [subjectId], references: [id])

  createdById String? @map("created_by")
  createdBy   User?   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  answerOptions     AnswerOption[]
  sessionQuestions  SessionQuestion[]

  @@map("questions")
}

// ============================================
// 4. JAVOB VARIANTLARI
// ============================================

model AnswerOption {
  id           String  @id @default(uuid())
  optionLabel  String  @map("option_label") @db.Char(1) // 'A', 'B', 'C', 'D'
  optionText   String  @map("option_text")
  isCorrect    Boolean @default(false) @map("is_correct")
  displayOrder Int     @default(0) @map("display_order") @db.SmallInt

  questionId String   @map("question_id")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  // Relations
  sessionQuestions SessionQuestion[]

  @@unique([questionId, optionLabel]) // bir savolda A,B,C,D takrorlanmasin
  @@map("answer_options")
}

// ============================================
// 5. O'QUVCHILAR
// ============================================

model Student {
  id        String   @id @default(uuid())
  fullName  String   @map("full_name") @db.VarChar(100)
  phone     String   @unique @db.VarChar(20)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  testSessions TestSession[]

  @@map("students")
}

// ============================================
// 6. TEST SESSIYASI
// ============================================

model TestSession {
  id             String    @id @default(uuid())
  requestedCount Int       @map("requested_count") @db.SmallInt // o'quvchi nechta savol so'ragani (max 50)
  actualCount    Int       @map("actual_count") @db.SmallInt // aslida nechta savol berildi
  score          Int?      @db.SmallInt // to'g'ri javoblar soni (yakunlangach to'ladi)
  percentage     Decimal?  @db.Decimal(5, 2)
  startedAt      DateTime  @default(now()) @map("started_at")
  finishedAt     DateTime? @map("finished_at")
  durationSec    Int?      @map("duration_sec")

  studentId String  @map("student_id")
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  subjectId String  @map("subject_id")
  subject   Subject @relation(fields: [subjectId], references: [id])

  // Relations
  sessionQuestions SessionQuestion[]

  @@map("test_sessions")
}

// ============================================
// 7. SESSIYA SAVOLLARI
// ============================================

model SessionQuestion {
  id           String    @id @default(uuid())
  displayOrder Int       @map("display_order") @db.SmallInt
  isCorrect    Boolean?  @map("is_correct") // null = javob bermadi
  answeredAt   DateTime? @map("answered_at")

  sessionId String      @map("session_id")
  session   TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  questionId String   @map("question_id")
  question   Question @relation(fields: [questionId], references: [id])

  selectedOptionId String?       @map("selected_option_id")
  selectedOption   AnswerOption? @relation(fields: [selectedOptionId], references: [id])

  @@unique([sessionId, questionId]) // bir sessiyada savol takrorlanmasin
  @@map("session_questions")
}